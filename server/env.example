# Authentication mode: local | sso | hybrid
AUTH_MODE=local

# JWT secret (change in production!)
JWT_SECRET=dev-secret-change-in-production

# Azure Entra ID / MSAL config (required when AUTH_MODE=sso or hybrid)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback
