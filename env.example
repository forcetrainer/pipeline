# ===========================================
# Pipeline — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values:
#   cp env.example .env

# Auth mode: local | sso | hybrid
AUTH_MODE=local

# JWT secrets — MUST be different for dev and prod
DEV_JWT_SECRET=change-me-dev-secret
PROD_JWT_SECRET=change-me-prod-secret-use-a-real-secret

# Image tag — the build script sets this automatically
# Override to pin a specific version
IMAGE_TAG=latest
